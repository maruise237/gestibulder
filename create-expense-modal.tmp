     1	'use client';
     2
     3	import React, { useState, useEffect, useCallback } from 'react';
     4	import { addExpense } from '@/lib/server/expense.actions';
     5	import { NewExpense } from "@/types/expense";
     6	import { getWorkers } from '@/lib/server/worker.actions';
     7	import { Loader2, Plus, Wallet, Calendar, HardHat, ReceiptText, Banknote, UserPlus, Check } from 'lucide-react';
     8	import { Project } from '@/types/project';
     9	import { Worker } from '@/types/worker';
    10	import { Button } from '@/components/ui/button';
    11	import {
    12	  Dialog,
    13	  DialogContent,
    14	  DialogDescription,
    15	  DialogHeader,
    16	  DialogTitle,
    17	  DialogTrigger,
    18	  DialogFooter,
    19	} from '@/components/ui/dialog';
    20	import { Input } from '@/components/ui/input';
    21	import { Label } from '@/components/ui/label';
    22	import {
    23	  Select,
    24	  SelectContent,
    25	  SelectItem,
    26	  SelectTrigger,
    27	  SelectValue,
    28	} from '@/components/ui/select';
    29	import { cn } from '@/lib/utils';
    30	import { useApp } from '@/lib/context/app-context';
    31	import { useMutation, useQueryClient } from '@tanstack/react-query';
    32	import { Popover, PopoverContent, PopoverTrigger } from "@/components/ui/popover";
    33	import { Checkbox } from "@/components/ui/checkbox";
    34
    35	const CATEGORIES = [
    36	  { label: 'Matériaux', value: 'materiaux' },
    37	  { label: "Main d'œuvre", value: 'main_d_oeuvre' },
    38	  { label: 'Transport', value: 'transport' },
    39	  { label: 'Divers', value: 'divers' },
    40	];
    41
    42	export function CreateExpenseModal({
    43	  projects,
    44	  onExpenseCreated,
    45	}: {
    46	  projects: Project[];
    47	  onExpenseCreated?: () => void;
    48	}) {
    49	  const { enterprise } = useApp();
    50	  const [isOpen, setIsOpen] = useState(false);
    51	  const [error, setError] = useState<string | null>(null);
    52	  const [selectedCategory, setSelectedCategory] = useState<string>('');
    53	  const queryClient = useQueryClient();
    54	  const [selectedChantier, setSelectedChantier] = useState<string>("");
    55	  const [workers, setWorkers] = useState<Worker[]>([]);
    56	  const [isLoadingWorkers, setIsLoadingWorkers] = useState(false);
    57	  const [selectedWorkerIds, setSelectedWorkerIds] = useState<string[]>([]);
    58
    59	  const mutation = useMutation({
    60	    mutationFn: (data: NewExpense) => addExpense(data),
    61	    onSuccess: () => {
    62	      queryClient.invalidateQueries({ queryKey: ["expenses"] });
    63	      onExpenseCreated?.();
    64	      setIsOpen(false);
    65	      resetForm();
    66	    },
    67	    onError: (err: any) => {
    68	      setError(err.message);
    69	    },
    70	  });
    71
    72	  const resetForm = () => {
    73	    setSelectedCategory('');
    74	    setSelectedChantier('');
    75	    setSelectedWorkerIds([]);
    76	    setError(null);
    77	  };
    78
    79	  const fetchWorkers = useCallback(async () => {
    80	    if (!selectedChantier) return;
    81	    setIsLoadingWorkers(true);
    82	    const { workers: allWorkers } = await getWorkers(1, 1000);
    83	    if (allWorkers) {
    84	      const filtered = (allWorkers as Worker[]).filter(w => w.chantier_ids?.includes(selectedChantier));
    85	      setWorkers(filtered);
    86	    }
    87	    setIsLoadingWorkers(false);
    88	  }, [selectedChantier]);
    89
    90	  useEffect(() => {
    91	    if (selectedChantier && selectedCategory === 'main_d_oeuvre') {
    92	      fetchWorkers();
    93	    }
    94	  }, [selectedChantier, selectedCategory, fetchWorkers]);
    95
    96	  const handleSubmit = async (e: React.FormEvent<HTMLFormElement>) => {
    97	    e.preventDefault();
    98	    const formData = new FormData(e.currentTarget);
    99
   100	    if (!selectedCategory) {
   101	      setError('Veuillez sélectionner une catégorie');
   102	      return;
   103	    }
   104
   105	    const data: NewExpense = {
   106	      libelle: formData.get('libelle') as string,
   107	      montant: Number(formData.get('montant')),
   108	      categorie: selectedCategory as any,
   109	      date: formData.get('date') as string,
   110	      chantier_id: formData.get('chantier_id') as string,
   111	      entreprise_id: enterprise?.id || '',
   112	    };
   113
   114	    mutation.mutate(data);
   115	  };
   116
   117	  const toggleWorker = (id: string) => {
   118	    setSelectedWorkerIds(prev =>
   119	      prev.includes(id) ? prev.filter(wId => wId !== id) : [...prev, id]
   120	    );
   121	  };
   122
   123	  return (
   124	    <Dialog open={isOpen} onOpenChange={(open) => {
   125	      setIsOpen(open);
   126	      if (!open) resetForm();
   127	    }}>
   128	      <DialogTrigger asChild>
   129	        <Button>
   130	          <Plus className="mr-2 h-4 w-4" />
   131	          Nouvelle Dépense
   132	        </Button>
   133	      </DialogTrigger>
   134	      <DialogContent className="sm:max-w-[500px]">
   135	        <DialogHeader className="bg-muted/30 border-b p-6">
   136	          <div className="flex items-center gap-4">
   137	            <div className="bg-primary text-primary-foreground rounded-md p-2">
   138	              <Wallet size={20} />
   139	            </div>
   140	            <div className="space-y-1">
   141	              <DialogTitle>Nouvelle Dépense</DialogTitle>
   142	              <DialogDescription>Gestion des flux financiers</DialogDescription>
   143	            </div>
   144	          </div>
   145	        </DialogHeader>
   146
   147	        <form onSubmit={handleSubmit} className="space-y-6 p-8 pt-6">
   148	          <div className="grid gap-6">
   149	            <div className="space-y-2.5">
   150	              <Label className="text-muted-foreground flex items-center gap-2 text-[10px] font-black tracking-widest uppercase">
   151	                <Wallet size={14} className="text-indigo-600" /> Catégorie
   152	              </Label>
   153	              <div className="bg-muted/30 grid grid-cols-2 gap-2 rounded-xl border p-1">
   154	                {CATEGORIES.map((cat) => (
   155	                  <button
   156	                    key={cat.value}
   157	                    type="button"
   158	                    onClick={() => setSelectedCategory(cat.value)}
   159	                    className={cn(
   160	                      "h-10 rounded-lg text-[10px] font-black tracking-widest uppercase transition-all active:scale-95",
   161	                      selectedCategory === cat.value
   162	                        ? "bg-indigo-600 text-white shadow-lg shadow-indigo-600/20"
   163	                        : "text-muted-foreground hover:bg-muted/50"
   164	                    )}
   165	                  >
   166	                    {cat.label}
   167	                  </button>
   168	                ))}
   169	              </div>
   170	            </div>
   171
   172	            <div className="space-y-2.5">
   173	              <Label
   174	                htmlFor="chantier_id"
   175	                className="text-muted-foreground flex items-center gap-2 text-[10px] font-black tracking-widest uppercase"
   176	              >
   177	                <HardHat size={14} className="text-indigo-600" /> Affectation Chantier
   178	              </Label>
   179	              <select
   180	                id="chantier_id"
   181	                name="chantier_id"
   182	                required
   183	                value={selectedChantier}
   184	                onChange={(e) => {
   185	                  setSelectedChantier(e.target.value);
   186	                  setSelectedWorkerIds([]);
   187	                }}
   188	                className="bg-zinc-50 border-zinc-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-600/5 h-12 w-full cursor-pointer appearance-none rounded-xl px-4 font-bold outline-none"
   189	              >
   190	                <option value="">Sélectionner un chantier</option>
   191	                {projects.map((p) => (
   192	                  <option key={p.id} value={p.id}>
   193	                    {p.nom}
   194	                  </option>
   195	                ))}
   196	              </select>
   197	            </div>
   198
   199	            <div className="space-y-2.5">
   200	              <Label
   201	                htmlFor="libelle"
   202	                className="text-muted-foreground flex items-center gap-2 text-[10px] font-black tracking-widest uppercase"
   203	              >
   204	                <ReceiptText size={14} className="text-indigo-600" /> Libellé / Objet
   205	              </Label>
   206	              <Input
   207	                id="libelle"
   208	                name="libelle"
   209	                required
   210	                placeholder="Ex: Achat 100 sacs de ciment"
   211	                className="bg-zinc-50 border-zinc-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-600/5 h-12 rounded-xl px-4 font-bold outline-none"
   212	              />
   213	            </div>
   214
   215	            <div className="grid grid-cols-2 gap-6">
   216	              <div className="space-y-2">
   217	                <Label htmlFor="montant" className="text-muted-foreground flex items-center gap-2 text-[10px] font-black tracking-widest uppercase">
   218	                  <Banknote size={14} className="text-indigo-600" /> Montant ({enterprise?.devise || "DA"})
   219	                </Label>
   220	                <Input
   221	                  id="montant"
   222	                  name="montant"
   223	                  type="number"
   224	                  required
   225	                  placeholder="0.00"
   226	                  className="bg-zinc-50 border-zinc-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-600/5 h-12 rounded-xl px-4 font-bold outline-none"
   227	                />
   228	              </div>
   229	              <div className="space-y-2">
   230	                <Label htmlFor="date" className="text-muted-foreground flex items-center gap-2 text-[10px] font-black tracking-widest uppercase">
   231	                  <Calendar size={14} className="text-indigo-600" /> Date
   232	                </Label>
   233	                <Input
   234	                  id="date"
   235	                  name="date"
   236	                  type="date"
   237	                  required
   238	                  defaultValue={new Date().toISOString().split("T")[0]}
   239	                  className="bg-zinc-50 border-zinc-200 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-600/5 h-12 rounded-xl px-4 font-bold outline-none"
   240	                />
   241	              </div>
   242	            </div>
   243
   244	            {selectedCategory === "main_d_oeuvre" && (
   245	              <div className="space-y-2.5 animate-in fade-in slide-in-from-left-2 duration-300">
   246	                <Label className="text-muted-foreground flex items-center gap-2 text-[10px] font-black tracking-widest uppercase">
   247	                  <UserPlus size={14} className="text-indigo-600" /> Ouvrier(s)
   248	                </Label>
   249	                <Popover>
   250	                  <PopoverTrigger asChild>
   251	                    <Button
   252	                      variant="outline"
   253	                      type="button"
   254	                      disabled={!selectedChantier || isLoadingWorkers}
   255	                      className="bg-zinc-50 border-zinc-200 focus:border-indigo-600 h-12 w-full justify-between rounded-xl px-4 font-bold text-left overflow-hidden"
   256	                    >
   257	                      <span className="truncate">
   258	                        {isLoadingWorkers ? (
   259	                          <Loader2 className="h-4 w-4 animate-spin" />
   260	                        ) : selectedWorkerIds.length > 0 ? (
   261	                          `${selectedWorkerIds.length} sélectionné(s)`
   262	                        ) : (
   263	                          "Sélectionner"
   264	                        )}
   265	                      </span>
   266	                      <Check className={cn("h-4 w-4 shrink-0 ml-2", selectedWorkerIds.length > 0 ? "text-indigo-600" : "text-zinc-300")} />
   267	                    </Button>
   268	                  </PopoverTrigger>
   269	                  <PopoverContent className="w-[200px] p-0 rounded-xl" align="start">
   270	                    <div className="max-h-[200px] overflow-y-auto p-2 space-y-1">
   271	                      {workers.length === 0 ? (
   272	                        <p className="p-2 text-[10px] font-bold text-muted-foreground uppercase text-center italic">
   273	                          Aucun ouvrier trouvé
   274	                        </p>
   275	                      ) : (
   276	                        workers.map((worker) => (
   277	                          <label
   278	                            key={worker.id}
   279	                            className="flex items-center space-x-2 rounded-md p-2 hover:bg-zinc-100 transition-colors cursor-pointer"
   280	                          >
   281	                            <Checkbox
   282	                              checked={selectedWorkerIds.includes(worker.id)}
   283	                              onCheckedChange={() => toggleWorker(worker.id)}
   284	                            />
   285	                            <span className="text-xs font-bold uppercase truncate">{worker.nom_complet}</span>
   286	                          </label>
   287	                        ))
   288	                      )}
   289	                    </div>
   290	                  </PopoverContent>
   291	                </Popover>
   292	              </div>
   293	            )}
   294
   295	            {error && (
   296	              <div className="bg-destructive/10 border-destructive/20 mt-4 flex items-center gap-3 rounded-md border p-4 text-destructive text-xs">
   297	                {error}
   298	              </div>
   299	            )}
   300	          </div>
   301
   302	          <DialogFooter className="p-6">
   303	            <Button
   304	              type="button"
   305	              variant="outline"
   306	              onClick={() => setIsOpen(false)}
   307	              className="flex-1"
   308	            >
   309	              Annuler
   310	            </Button>
   311	            <Button
   312	              type="submit"
   313	              disabled={mutation.isPending}
   314	              className="flex-1"
   315	            >
   316	              {mutation.isPending ? (
   317	                <>
   318	                  <Loader2 className="mr-2 h-4 w-4 animate-spin" />
   319	                  Enregistrement...
   320	                </>
   321	              ) : (
   322	                'Enregistrer'
   323	              )}
   324	            </Button>
   325	          </DialogFooter>
   326	        </form>
   327	      </DialogContent>
   328	    </Dialog>
   329	  );
   330	}
