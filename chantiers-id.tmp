   432
   433	        {activeTab === 'finances' && (
   434	          <div className="space-y-6">
   435	            <div className="grid grid-cols-1 gap-4 md:grid-cols-2">
   436	              <Card className="group relative overflow-hidden border-border p-4 sm:p-6 rounded-2xl border-l-8 border-l-indigo-600">
   437	                <div className="mb-4 flex items-center gap-3">
   438	                  <div className="rounded-md bg-indigo-600/10 p-2 text-indigo-600">
   439	                    <Wallet size={18} />
   440	                  </div>
   441	                  <span className="text-[10px] font-black tracking-widest text-muted-foreground uppercase">
   442	                    Total Dépenses
   443	                  </span>
   444	                </div>
   445	                <p className="text-size-2xl font-black tracking-tight text-foreground">
   446	                  {formatCurrency(totalExpenses, enterprise?.devise)}
   447	                </p>
   448	                <div className="mt-2 flex items-center gap-1 text-emerald-600">
   449	                  <ArrowDownRight size={14} />
   450	                  <span className="text-[9px] font-black tracking-widest uppercase">
   451	                    Actualisé
   452	                  </span>
   453	                </div>
   454	              </Card>
   455
   456	              <Card className="group relative overflow-hidden border-border p-4 sm:p-6 rounded-2xl border-l-8 border-l-indigo-600">
   457	                <div className="mb-4 flex items-center gap-3">
   458	                  <div className={cn(
   459	                    "rounded-md p-2",
   460	                    marginValue > 0 ? "bg-emerald-500/10 text-emerald-600" : "bg-destructive/10 text-destructive"
   461	                  )}>
   462	                    {marginValue > 0 ? <TrendingUp size={18} /> : <TrendingDown size={18} />}
   463	                  </div>
   464	                  <span className="text-[10px] font-black tracking-widest text-muted-foreground uppercase">
   465	                    Marge (Currency)
   466	                  </span>
   467	                </div>
   468	                <p className={cn(
   469	                  "text-size-2xl font-black tracking-tight",
   470	                  marginValue > 0 ? "text-emerald-600" : "text-destructive"
   471	                )}>
   472	                  {formatCurrency(marginValue, enterprise?.devise)}
   473	                </p>
   474	                <p className="mt-2 text-[9px] font-black tracking-widest text-muted-foreground uppercase">
   475	                  {marginPct ? `${marginPct}% de rentabilité` : 'Rentabilité non calculable'}
   476	                </p>
   477	              </Card>
   478	            </div>
   479
   480	            <Card className="shadow-premium overflow-hidden border-border rounded-2xl" padding="none">
   481	              <div className="flex flex-col justify-between gap-4 border-b border-border bg-muted/30 p-4 sm:p-6 md:flex-row md:items-center">
   482	                <div className="flex items-center gap-3">
   483	                  <div className="rounded-md border border-border bg-background p-2">
   484	                    <Calculator size={18} className="text-indigo-600" />
   485	                  </div>
   486	                  <h2 className="text-size-lg font-black tracking-tight text-foreground uppercase">
   487	                    Grand Livre
   488	                  </h2>
   489	                </div>
   490	              </div>
   491
   492	              {expenses.length === 0 ? (
   493	                <div className="p-12 text-center text-muted-foreground">
   494	                  <Calculator size={32} className="mx-auto mb-2 opacity-10" />
   495	                  <p className="text-[10px] font-black uppercase italic">Aucune transaction enregistrée.</p>
   496	                </div>
   497	              ) : (
   498	                <div className="divide-y divide-border">
   499	                  {expenses.map((expense) => (
   500	                    <div
   501	                      key={expense.id}
   502	                      className="group flex items-center justify-between p-4 transition-all duration-200 hover:bg-muted/30 sm:p-6"
   503	                    >
   504	                      <div className="flex items-center gap-3 sm:gap-4">
   505	                        <div className={cn(
   506	                          'flex h-10 w-10 shrink-0 items-center justify-center rounded-md border transition-transform group-hover:scale-110',
   507	                          expense.categorie === 'materiaux' ? 'bg-amber-500/10 text-amber-600 border-amber-500/20' : 'bg-indigo-600/10 text-indigo-600 border-indigo-600/20'
   508	                        )}>
   509	                          {expense.categorie === 'materiaux' ? <Package size={18} /> : <Calculator size={18} />}
   510	                        </div>
   511	                        <div className="min-w-0">
   512	                          <div className="truncate text-size-sm font-black text-foreground group-hover:text-indigo-600 uppercase">
   513	                            {expense.libelle}
   514	                          </div>
   515	                          <div className="mt-1 flex items-center gap-2 text-[9px] font-semibold text-muted-foreground uppercase">
   516	                            <span>{new Date(expense.date).toLocaleDateString()}</span>
   517	                            <span>•</span>
   518	                            <span>{expense.categorie.replace(/_/g, ' ')}</span>
   519	                          </div>
   520	                        </div>
   521	                      </div>
   522	                      <div className="flex items-center gap-4 sm:gap-6">
   523	                        <div className="text-right">
   524	                          <div className="text-size-sm font-black text-destructive sm:text-size-base uppercase">
   525	                            - {formatCurrency(expense.montant, enterprise?.devise)}
   526	                          </div>
   527	                        </div>
   528	                      </div>
   529	                    </div>
   530	                  ))}
   531	                </div>
   532	              )}
   533	            </Card>
   534	          </div>
   535	        )}
   536	      </div>
   537	    </div>
   538	  );
   539	}
