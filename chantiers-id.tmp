   417	                        </div>
   418	                      </div>
   419
   420	                      <div className="mt-auto flex items-center justify-between">
   421	                         <span className="text-[8px] font-semibold text-muted-foreground uppercase">
   422	                           Maj {new Date(mat.created_at).toLocaleDateString()}
   423	                         </span>
   424	                      </div>
   425	                    </div>
   426	                  </Card>
   427	                );
   428	              })
   429	            )}
   430	          </div>
